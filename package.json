{
  "name": "@karyl-chan/plugin-radio",
  "version": "0.7.1",
  "description": "Internet radio + YouTube audio library with WebUI management.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite build && tsx watch src/index.ts",
    "build": "rm -rf dist && vite build && tsc",
    "build:ui": "vite build",
    "build:server": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.3",
    "@iconify/vue": "^5.0.0",
    "@karyl-chan/plugin-sdk": "^0.7.0",
    "@karyl-chan/ui": "^0.1.0",
    "@popperjs/core": "^2.11.8",
    "better-sqlite3": "^12.10.0",
    "nanoid": "^3.3.11",
    "pinia": "^3.0.4",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^5.2.1",
    "fastify": "^5.0.0",
    "sortablejs": "^1.15.7",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^4.1.7",
    "vue": "^3.5.13"
  },
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
