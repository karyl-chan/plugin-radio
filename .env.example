# Karyl Radio plugin — environment knobs. Everything here is optional and
# shown with its default; uncomment only what you need to override.
# (When run from the monorepo's docker-compose.yml the relevant ones are
#  already set there — see ../../.env.example for the host-side .env.)

# Per-plugin setup secret (32-byte hex). Provisioned by the bot admin via
# POST /api/plugins/setup-secret { pluginKey: "karyl-radio" }. Without it the
# plugin still starts but can't register with the bot.
# KARYL_PLUGIN_SETUP_SECRET=

# Where the bot is reachable.
# BOT_URL=http://karyl-chan:3000

# URL the bot uses to dispatch back to this plugin. Default is
# http://<pluginKey>:3000 (= http://karyl-radio:3000); override it to the
# actual container/host name (the docker-compose service is karyl-plugin-radio)
# or when sitting behind a reverse proxy.
# PLUGIN_URL=http://karyl-plugin-radio:3000

# Listen address.
# PORT=3000
# HOST=0.0.0.0

# Where downloaded audio and uploaded cover images live.
# MUSIC_DIR=/app/data/music
# COVER_DIR=/app/data/covers

# Optional fallback/override for the browser-reachable base URL of the radio
# WebUI. Normally unused — the bot proxies the WebUI at <bot>/plugin/karyl-radio/
# when WEB_BASE_URL is set on the bot, and publicBaseUrl is supplied via the
# register/heartbeat response. Set this only for direct-access debugging (and
# re-add a port mapping in docker-compose.yml).
# RADIO_PUBLIC_URL=http://localhost:903
